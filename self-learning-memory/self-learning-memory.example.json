{
  "statePath": ".pi/self-learning-memory/state.json",
  "retrievalLimit": 6,
  "cacheWindowMs": 600000,
  "immediateExtraction": true,
  "sessionRetentionLimit": 500,
  "maxEventsPerSession": 200,
  "autoConsolidation": {
    "minimumConfidence": 0.9,
    "minimumIndependentSessions": 2,
    "allowedTypes": ["preference", "fact"]
  },
  "economyModel": {
    "provider": "openai",
    "model": "gpt-4.1-mini",
    "thinking": "low"
  },
  "warmModel": {
    "provider": "openai",
    "model": "gpt-4.1-mini",
    "thinking": "low"
  },
  "consolidationModel": {
    "provider": "openai",
    "model": "gpt-4.1-mini",
    "thinking": "low"
  },
  "redactionPatterns": [
    "customer[-_ ]?id\\s*[:=]\\s*[^\\s,;]+"
  ]
}
